# FutureAuth's own database (Neon Postgres)
DATABASE_URL=postgres://user:password@localhost:5432/futureauth?sslmode=prefer

# HMAC secret for hashing API keys and project secrets (required, use a long random string)
HMAC_SECRET=change-me-to-a-random-secret

# Server
PORT=3002

# CORS origin for the dashboard frontend
CORS_ORIGIN=http://localhost:5180

# Resend (required — used for dashboard login OTP + email-mode projects)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@auth.future-auth.com

# Twilio (optional — enables phone OTP mode for projects)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+15551234567
